<%- include('header', { pageTitle: article.title, siteName: siteName, basePath: basePath, pages: pages }) %>

<article class="post-full">
  <header class="post-header">
    <h1 class="post-title"><%= article.title %></h1>
    <div class="post-meta">
      <% if (article.date) { %>
        <span class="post-date">📅 <%= article.date %></span>
      <% } %>
      <span class="post-updated">🕒 更新于 <%= article.updatedAt %></span>
    </div>
  </header>

  <div class="post-content">
    <%- article.htmlContent %>
  </div>
</article>

<div class="post-nav">
  <a href="<%= basePath %>/" class="back-home">← 返回首页</a>
</div>

<%- include('footer', { siteName: siteName, basePath: basePath }) %>
