<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof pageTitle !== 'undefined' && pageTitle ? pageTitle + ' - ' : '' %><%= siteName %></title>
  <base href="<%= basePath %>/">
  <link rel="stylesheet" href="css/style.css">
</head>
<body>
  <header class="site-header">
    <div class="container">
      <a href="<%= basePath %>/" class="site-logo"><%= siteName %></a>
      <nav class="site-nav">
        <a href="<%= basePath %>/">首页</a>
        <% if (typeof hasLinks !== 'undefined' && hasLinks) { %>
          <a href="<%= basePath %>/links">友链</a>
        <% } %>
        <% if (typeof pages !== 'undefined' && pages.length > 0) { %>
          <% pages.forEach(function(p) { %>
            <a href="<%= basePath %>/page/<%= p.name %>"><%= p.name %></a>
          <% }); %>
        <% } %>
      </nav>
    </div>
  </header>
  <main class="site-main container">
